# -----------------------------------------------------------------------
# Backend API
# Dev: http://localhost:8000/api/v1
# Prod: https://your-backend.onrender.com/api/v1
# -----------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------
# This app's own URL (for absolute links, OG tags)
# Dev: http://localhost:3000
# Prod: your Vercel URL
# -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------
# Stripe — needed from Phase 5
# dashboard.stripe.com → Developers → API keys → Publishable key (pk_test_...)
# Only needed if using embedded Stripe Elements; not required for hosted Checkout
# -----------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------
# Vapi (voice) — needed from Phase 6
# vapi.ai → API Keys → Public Key
# -----------------------------------------------------------------------
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# -----------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_VOICE=true
