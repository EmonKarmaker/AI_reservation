# -----------------------------------------------------------------------
# Database
# Supabase: Project Settings → Database → Connection string → URI tab
# Replace postgresql:// with the async/sync driver prefixes below
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@db.xxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------
# Security
# JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
# PLATFORM_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------
JWT_SECRET_KEY=0gStpfHhjlR0xlDCyv5DPgMwAjxVXf_auYA07pHHOglR63CS5hsDy2onLX_04yJtyttpffXDduoB2H3Qngyz0A
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
PLATFORM_ENCRYPTION_KEY=WEgmzIEbLZ1QBBrsGw1AnL0eCscCPtLSaIN3qrxN2KU=

# -----------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_ORIGIN=http://localhost:8000
ENVIRONMENT=dev
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# LLM (Groq) — needed from Phase 4
# console.groq.com → API Keys → Create API Key (free tier)
# -----------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# -----------------------------------------------------------------------
# Embeddings — needed from Phase 3
# -----------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# -----------------------------------------------------------------------
# Stripe (test mode) — needed from Phase 5
# dashboard.stripe.com → Developers → API keys
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/demo/{slug}/booking/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/demo/{slug}/booking/cancelled

# -----------------------------------------------------------------------
# Vapi (voice) — needed from Phase 6
# vapi.ai → API Keys
# -----------------------------------------------------------------------
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID_DEFAULT=

# -----------------------------------------------------------------------
# Email (Resend) — needed from Phase 5
# resend.com → API Keys (free: 3,000 emails/month)
# -----------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_REPLY_TO=

# -----------------------------------------------------------------------
# Supabase Storage — needed from Phase 2
# Supabase → Project Settings → API
# -----------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=business-assets

# -----------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------
SCHEDULER_ENABLED=true
